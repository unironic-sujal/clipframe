# Dependencies
node_modules/

# Terraform state (never commit state files — they may contain secrets)
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfvars

# Ansible vault / sensitive files
ansible/*.vault
ansible/vault_pass.txt

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Secrets — NEVER commit these
*.pem
*.key
*.crt
kubeconfig
.env
.env.*

# Build artifacts
dist/
build/
analytics.min.js

# Temp/diagnostic scripts
diag*.js
visit.js
check-*.js
test-analytics*.js
analytics.js

# Test videos
*.mp4

# Kind binary
kind.exe
